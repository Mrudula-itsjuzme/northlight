# Northlight environment variables.
# Copy this file to `.env.local` for local development (Next.js loads
# .env.local automatically) and never commit real secrets.

# ---------------------------------------------------------------------------
# Supabase — data plane (Postgres, Auth, Storage, RLS, pgvector)
# ---------------------------------------------------------------------------

# Public project URL, e.g. https://xxxxxxxx.supabase.co
# Safe to expose to the browser (NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_SUPABASE_URL=

# Public "anon" API key. Safe to expose to the browser — access control is
# enforced entirely by Postgres Row Level Security (RLS) policies, not by
# keeping this key secret.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key. FULL ADMIN ACCESS, BYPASSES ALL RLS POLICIES.
# Server-only. Never prefix with NEXT_PUBLIC_. Never import into any module
# that could be bundled into client code. Used only by the background job
# worker and a small number of trusted server routes/scripts (e.g. demo
# data seeding).
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string used by Drizzle for schema migrations
# and typed queries from server-only code (route handlers, server actions,
# the worker, scripts). Get this from Supabase Project Settings > Database.
# Example: postgres://postgres:[password]@[host]:5432/postgres
DATABASE_URL=

# ---------------------------------------------------------------------------
# LLM provider — OpenAI (optional)
# ---------------------------------------------------------------------------

# If unset, Northlight runs entirely on deterministic demo/mock adapters for
# embeddings, brief/article generation, and AI visibility checks. These are
# clearly labeled "Demo" in the UI. Northlight will NEVER call a real
# external provider without this key configured, and will never fake a
# "success" response from a real provider.
OPENAI_API_KEY=

# Optional: override the default chat + embedding models.
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------

# Base URL of the deployed app, used for building absolute links (e.g. in
# invite emails). Defaults to http://localhost:3000 in development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shared secret used to authorize calls to the internal job worker route
# (e.g. from a Vercel Cron job hitting /api/jobs/run). Generate any random
# string for local dev; use a strong random value in production.
JOBS_WORKER_SECRET=

# ---------------------------------------------------------------------------
# Testing (used only by the Vitest suite, not the running app)
# ---------------------------------------------------------------------------

# Connection string for the ephemeral in-process Postgres (pglite) used by
# integration tests to validate migrations and RLS-equivalent logic without
# a real Supabase project. Not needed for `npm run dev`.
TEST_DATABASE_URL=pglite
